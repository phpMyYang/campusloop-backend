# Copy to .env on the EC2 server (never commit):
#   cp .env.production.example .env

APP_NAME=CampusLoop
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# RDS — values also mirrored in compose.prod.env for Docker
DB_CONNECTION=mysql
DB_HOST=your-rds-endpoint.ap-southeast-1.rds.amazonaws.com
DB_PORT=3306
DB_DATABASE=campusloop
DB_USERNAME=campusloop
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
FILESYSTEM_PUBLIC_DRIVER=s3
QUEUE_CONNECTION=database
CACHE_STORE=database

# Leave blank on EC2 — use IAM instance role for S3 access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=campusloop-prod-uploads-your-unique-id
AWS_URL=https://campusloop-prod-uploads-your-unique-id.s3.ap-southeast-1.amazonaws.com
AWS_USE_PATH_STYLE_ENDPOINT=false

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=campusloop
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=your-domain.com
REVERB_PORT=443
REVERB_SCHEME=https

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

SANCTUM_STATEFUL_DOMAINS=your-domain.com,www.your-domain.com
