# Copy to compose.env in the backend repo root (same folder as compose.yaml):
#   cp docker/compose.env.example compose.env
#
# Docker Compose loads compose.env automatically when you run:
#   docker compose --env-file compose.env up --build
#
# Or export these in your shell before running docker compose.

# --- Cross-repo paths (separate git repos) ---
# Relative path from backend repo root (default: sibling folder)
CAMPUSLOOP_FRONTEND_DIR=../campusloop-frontend

# Windows example (use forward slashes):
# CAMPUSLOOP_FRONTEND_DIR=C:/Users/you/projects/campusloop-frontend
#
# WSL tip: cloning under /mnt/c/... is slow and can break Composer.
# Prefer ~/projects/... on the Linux filesystem for better Docker performance.

# --- Ports (change if already in use) ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
MYSQL_PORT=3306
REVERB_PORT=8080

# --- Database ---
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=campusloop
MYSQL_USER=campusloop
MYSQL_PASSWORD=secret

# --- App URLs (browser-facing; keep localhost for local dev) ---
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api

# --- Frontend (passed to Vite inside Docker; overrides frontend/.env if set) ---
# Google test site key (always passes on localhost):
# VITE_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
VITE_RECAPTCHA_SITE_KEY=

# --- Reverb (WebSockets) ---
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_APP_ID=campusloop
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret

# --- File watching (set true on Windows Docker Desktop / some WSL mounts) ---
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
