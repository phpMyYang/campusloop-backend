# Copy to compose.prod.env in the backend repo root:
#   cp docker/compose.prod.env.example compose.prod.env
#
# Usage:
#   docker compose -f compose.prod.yaml --env-file compose.prod.env up -d --build

# --- Repo paths on EC2 ---
CAMPUSLOOP_FRONTEND_DIR=/opt/campusloop/campusloop-frontend

# --- Ports (host nginx proxies to these) ---
BACKEND_PORT=8000
FRONTEND_PORT=8080
REVERB_PORT=8081

# --- Public URLs ---
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
VITE_API_BASE_URL=https://your-domain.com/api
SANCTUM_STATEFUL_DOMAINS=your-domain.com,www.your-domain.com

# --- RDS (no MySQL container in prod) ---
DB_HOST=your-rds-endpoint.ap-southeast-1.rds.amazonaws.com
DB_PORT=3306
DB_DATABASE=campusloop
DB_USERNAME=campusloop
DB_PASSWORD=change-me

# --- S3 (use EC2 IAM role — leave AWS keys empty in .env) ---
FILESYSTEM_DISK=s3
FILESYSTEM_PUBLIC_DRIVER=s3
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=campusloop-prod-uploads-your-unique-id
AWS_URL=https://campusloop-prod-uploads-your-unique-id.s3.ap-southeast-1.amazonaws.com

# --- Frontend build args ---
VITE_RECAPTCHA_SITE_KEY=

# --- Reverb (optional: enable with --profile reverb) ---
BROADCAST_CONNECTION=reverb
REVERB_HOST=your-domain.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_APP_ID=campusloop
REVERB_APP_KEY=change-me
REVERB_APP_SECRET=change-me

# --- Migrations on container start (CI workflow also runs migrate) ---
MIGRATE_ON_START=false
